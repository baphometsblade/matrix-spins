{
  "manifest_version": 3,
  "name": "Affiliate Transparency Extension",
  "version": "1.0",
  "description": "Monitors affiliate links and alerts users of last-click attribution.",
  "permissions": [
    "webRequest",
    "cookies",
    "storage",
    "notifications",
    "tabs",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>",
    "*://my-partner-network.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "options_page": "settings.html",
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["partners.json"],
      "matches": ["<all_urls>"]
    }
  ]
}