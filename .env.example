# ════════════════════════════════════════════════
#  Matrix Spins Casino — Environment Variables
#  Copy this file to .env and fill in real values
#  NEVER commit .env to git
# ════════════════════════════════════════════════

NODE_ENV=production

# ── Security (generate strong random values) ──────────────────
JWT_SECRET=replace-with-64-char-random-string
ADMIN_PASSWORD=replace-with-strong-admin-password
WEBHOOK_SECRET=replace-with-32-char-random-string

# ── Stripe Payments ────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Crypto Wallets ─────────────────────────────────────────────
CRYPTO_WALLET_ADDRESS=0x5cee55FF03c247c1C2b4b9b4e732B087758CD863
BTC_WALLET_ADDRESS=bc1qtl6rrtzcnrjycjdccm08d42u2qucu7qnz7ma0q

# ── Email / SMTP (optional — enables password reset) ───────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=noreply@msaart.online
# SMTP_PASS=your-app-password
# ADMIN_EMAIL=admin@msaart.online

# ── Database (REQUIRED FOR PRODUCTION — without this, money ops are blocked) ──
# Get a free PostgreSQL instance from one of:
#   - Neon (https://neon.tech) — recommended, generous free tier
#   - Supabase (https://supabase.com)
#   - Render PostgreSQL (paid)
# Format: postgresql://user:pass@host:5432/dbname?sslmode=require
DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require

# ── Withdrawal OTP threshold (USD) ─────────────────────────────
# Withdrawals at or above this amount require email OTP verification
# before admin can approve. Default: 500
WITHDRAWAL_OTP_THRESHOLD=500

# ── Optional: Sentry error monitoring ──────────────────────────
# SENTRY_DSN=https://...@sentry.io/...

# ── CORS ────────────────────────────────────────────────────────
ALLOWED_ORIGIN=https://msaart.online

# ── Jurisdictional Geo-Blocking ─────────────────────────────────
# REQUIRED FOR REAL-MONEY OPERATION. Leave both empty during dev.
# ALLOWED_COUNTRIES: comma-separated ISO-3166-1 alpha-2 codes. Only
#   users from these countries can register / deposit / withdraw.
#   Set this to the jurisdiction(s) covered by your gambling licence.
# BLOCKED_COUNTRIES: optional explicit deny list (applied even if
#   ALLOWED_COUNTRIES is empty). Useful to forbid US, UK, FR, etc.
# GEO_FAIL_MODE: "open" (default — allow on lookup failure) or
#   "closed" (deny on lookup failure). Use "closed" for strict
#   jurisdictions once you've confirmed the geo provider is reliable.
# ALLOWED_COUNTRIES=
# BLOCKED_COUNTRIES=US,GB,FR,SG
# GEO_FAIL_MODE=open
