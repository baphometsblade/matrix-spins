# ═══════════════════════════════════════════════════════════
# Matrix Spins Casino — Environment Configuration
# Copy this file to .env and fill in your values. Do NOT commit .env.
# In production (NODE_ENV=production) the server will refuse to start
# if any REQUIRED variable is missing — see server/index.js startup check.
# ═══════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
BASE_URL=https://msaart.online
APP_URL=https://msaart.online                          # Stripe checkout success/cancel redirect base
ALLOWED_ORIGIN=https://msaart.online                   # CORS — comma-separated list if multiple

# ── Database ──────────────────────────────────────────────
# SQLite fallback (dev / degraded mode). Money ops disabled when PG unreachable.
DB_PATH=./casino.db
# PostgreSQL (production REQUIRED)
DATABASE_URL=postgresql://user:password@host:5432/casino_db

# ── Authentication (REQUIRED) ─────────────────────────────
# JWT_SECRET: 32+ chars, kept stable across restarts (random per-restart
# would log out every user). Generate with: openssl rand -hex 64
JWT_SECRET=REPLACE_WITH_openssl_rand_-hex_64
JWT_EXPIRY=4h
BCRYPT_ROUNDS=12

# ── Admin (REQUIRED in production) ────────────────────────
# ADMIN_PASSWORD: 12+ chars. A random per-restart value locks the admin out.
ADMIN_USERNAME=matrix
ADMIN_PASSWORD=REPLACE_WITH_openssl_rand_-base64_18
ADMIN_EMAIL=admin@msaart.online
ADMIN_RESET_SECRET=REPLACE_WITH_openssl_rand_-hex_32    # For emergency admin reset endpoint
ADMIN_DASHBOARD_TOKEN=REPLACE_WITH_openssl_rand_-hex_32 # Dashboard access token

# ── Stripe Payments (REQUIRED for deposits) ───────────────
# Without STRIPE_SECRET_KEY, all deposit routes return 503.
# When STRIPE_SECRET_KEY is set, STRIPE_WEBHOOK_SECRET is also required
# (otherwise the server refuses to start in production).
# Get keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_REPLACE_WITH_YOUR_LIVE_KEY
STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE_WITH_YOUR_LIVE_KEY
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_WEBHOOK_SECRET
# Optional — pre-created Stripe Price IDs per preset amount. If unset, the
# checkout route builds price_data dynamically. Do NOT use sk_test_ price IDs
# with a live-mode secret key; Stripe returns "No such price" errors.
# STRIPE_PRICE_5=price_...
# STRIPE_PRICE_10=price_...
# STRIPE_PRICE_25=price_...
# STRIPE_PRICE_50=price_...
# STRIPE_PRICE_100=price_...
# STRIPE_PRICE_250=price_...

# ── Generic webhook (PayPal / manual admin) ───────────────
WEBHOOK_SECRET=REPLACE_WITH_openssl_rand_-hex_32

# ── Server-Side RNG (REQUIRED) ────────────────────────────
# Seed chain for provably-fair spin results. Regenerating this invalidates
# historical verifiability.
RNG_SERVER_SECRET=REPLACE_WITH_openssl_rand_-hex_128

# ── Email (SMTP — REQUIRED for password reset) ────────────
SMTP_HOST=smtp.postmarkapp.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM="Matrix Spins <noreply@msaart.online>"

# ── Crypto Deposits (optional) ────────────────────────────
CRYPTO_WALLET_ADDRESS=                                 # ETH receiving address
BTC_WALLET_ADDRESS=                                    # BTC receiving address
ETH_RPC_URL=https://cloudflare-eth.com
ETH_CHAIN_ID=1
CRYPTO_MIN_CONFIRMATIONS=2
ETH_AUD_FALLBACK_RATE=5000

# ── Blockchain audit trail (optional, disabled by default) ──
# When CONTRACT_ADDRESS is unset, blockchain runs in simulated mode —
# DB is the source of truth. Fill in to enable on-chain mint/burn records.
THIRDWEB_SECRET_KEY=
POLYGON_RPC_URL=https://polygon-rpc.com
CONTRACT_ADDRESS=
PRIVATE_KEY=

# ── Error monitoring (recommended) ────────────────────────
SENTRY_DSN=

# ── Rate Limiting (defaults sensible) ─────────────────────
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100
