# Matrix Spins — environment.
#
# There are no defaults. The server refuses to start unless every
# required value below is set. Copy this file to `.env` for local
# development, or configure the equivalent values in your host's
# dashboard for production.

# ── General ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# Required in production. Must be https://<your-domain> so Stripe
# success_url / cancel_url and password-reset links work.
PUBLIC_URL=http://localhost:3000

# Required in production. Used to lock CORS to your frontend origin.
ALLOWED_ORIGIN=http://localhost:3000

# ── Auth secrets ─── REQUIRED EVERYWHERE ────────────────────────────────
# Generate each with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
ADMIN_PASSWORD=
NFT_SIGNING_SECRET=

# Optional, defaults to "admin"
ADMIN_USERNAME=admin

# ── Database ─── PICK ONE ───────────────────────────────────────────────
# Set DATABASE_URL to a Postgres connection string for production:
DATABASE_URL=
# OR set SQLITE_FILE to a local SQLite path for dev / single-instance deploys.
# Production with SQLITE_FILE is allowed but the server warns about
# data loss on redeploy.
SQLITE_FILE=./server/data.sqlite

# ── Stripe ─── REQUIRED IN PRODUCTION; all three or none ────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── SMTP ─── REQUIRED IN PRODUCTION; all three or none ──────────────────
# SMTP_USER / SMTP_PASS are only needed if your provider requires auth.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── NFT provider (optional) ─────────────────────────────────────────────
# 'db' issues signed off-chain receipts (default). Replace with a real
# mint provider name once you wire nft.service.js::mintFor() to it.
NFT_PROVIDER=db

# ── Maintenance ─────────────────────────────────────────────────────────
# Set to 1 to return 503 on all /api routes except /health, /auth/login, /admin.
MAINTENANCE_MODE=0
