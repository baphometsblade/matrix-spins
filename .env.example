# ═══════════════════════════════════════════════════════════
# Royal Slots Casino — Environment Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────
# SQLite (default for development)
DB_TYPE=sqlite
DB_PATH=./casino.db

# PostgreSQL (production)
# DB_TYPE=postgres
# DATABASE_URL=postgresql://user:password@localhost:5432/royal_slots

# ── Authentication ────────────────────────────────────────
JWT_SECRET=your-jwt-secret-here-change-in-production
JWT_EXPIRY=24h
BCRYPT_ROUNDS=12

# ── Stripe Payments ───────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
# Generic webhook secret for /api/payment/webhook/confirm (not Stripe — used by PayPal/manual admin)
WEBHOOK_SECRET=your-webhook-secret-here

# ── Server-Side RNG ───────────────────────────────────────
RNG_SERVER_SECRET=your-rng-secret-change-in-production

# ── Blockchain (Backend Only — Never Exposed to Players) ──
THIRDWEB_SECRET_KEY=your-thirdweb-secret-here
POLYGON_RPC_URL=https://polygon-rpc.com
CONTRACT_ADDRESS=0x_your_deployed_contract_address
PRIVATE_KEY=0x_deployer_wallet_private_key

# ── Email (Optional) ──────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ── Sentry Error Tracking (Optional) ─────────────────────
SENTRY_DSN=https://your-sentry-dsn-here

# ── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

