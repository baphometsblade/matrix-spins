# ════════════════════════════════════════════════
#  Matrix Spins Casino — Environment Variables
#  Copy this file to .env and fill in real values
#  NEVER commit .env to git
# ════════════════════════════════════════════════

NODE_ENV=production

# ── Security (generate strong random values) ──────────────────
JWT_SECRET=replace-with-64-char-random-string
ADMIN_PASSWORD=replace-with-strong-admin-password
WEBHOOK_SECRET=replace-with-32-char-random-string

# ── Stripe Payments ────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Crypto Wallets ─────────────────────────────────────────────
CRYPTO_WALLET_ADDRESS=0x5cee55FF03c247c1C2b4b9b4e732B087758CD863
BTC_WALLET_ADDRESS=bc1qtl6rrtzcnrjycjdccm08d42u2qucu7qnz7ma0q

# ── Email / SMTP (optional — enables password reset) ───────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=noreply@msaart.online
# SMTP_PASS=your-app-password
# ADMIN_EMAIL=admin@msaart.online

# ── Database (optional — defaults to SQLite) ───────────────────
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── CORS ────────────────────────────────────────────────────────
ALLOWED_ORIGIN=https://msaart.online
