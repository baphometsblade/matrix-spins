# Matrix Spins — environment variables.
# Copy to `.env` for local development. For production, set these in
# your Render dashboard (or equivalent) — never commit a real .env.

# ── General ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
PUBLIC_URL=http://localhost:3000
ALLOWED_ORIGIN=

# ── Auth secrets ─────────────────────────────────────────────────────────
# Required in production. A random value is generated at boot for dev.
JWT_SECRET=
ADMIN_PASSWORD=

# ── Database ─────────────────────────────────────────────────────────────
# If DATABASE_URL is set, Postgres is used. Otherwise a SQLite file is
# created at SQLITE_FILE (default ./server/data.sqlite). SQLite is fine
# for development and single-instance deploys; for real production
# traffic, use Postgres so users and balances survive restarts.
DATABASE_URL=
SQLITE_FILE=./server/data.sqlite

# ── Stripe ───────────────────────────────────────────────────────────────
# Required before /api/deposit/checkout will create a real Stripe Checkout
# session. Without these, the endpoint returns 503 and no balance moves.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Required to verify webhook signatures. Without it, the webhook endpoint
# refuses to process any incoming event. Never run production without it.
STRIPE_WEBHOOK_SECRET=

# ── NFT receipts ─────────────────────────────────────────────────────────
# Provider for on-chain receipts (v1 issues DB-backed receipts).
# 'db' = local signed record. Swap to 'crossmint' / 'thirdweb' and add
# provider-specific keys once you've chosen a chain and contract.
NFT_PROVIDER=db
# Stable HMAC secret used to sign receipt metadata. If absent, a random
# one is generated per boot — existing signatures become unverifiable
# after a restart, so set this in production.
NFT_SIGNING_SECRET=

# ── Maintenance / ops ────────────────────────────────────────────────────
# Set to 1 to return 503 from all /api routes except health and login.
MAINTENANCE_MODE=0
