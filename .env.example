# ─────────────────────────────────────────────────────────────────────
# Matrix Spins Casino — Environment Variable Reference
#
# Copy this file to `.env` for local development.
# In production (Render / Vercel / Docker) set these in the platform
# dashboard — never commit a real .env file.
#
# Legend:  [REQUIRED]    server cannot earn money without this
#          [recommended] feature degraded if missing
#          [optional]    nice-to-have / sane default applied
# ─────────────────────────────────────────────────────────────────────

# ── Runtime ──────────────────────────────────────────────────────────
NODE_ENV=development                # development | production | test
PORT=3000                           # HTTP port the server binds to
LOG_LEVEL=info                      # error | warn | info | debug

# ── Database ─────────────────────────────────────────────────────────
# [REQUIRED] PostgreSQL connection string. Without this the server runs
# SQLite which is wiped on every container restart — money operations
# are blocked in degraded mode. Format:
#   postgresql://user:pass@host:5432/dbname?sslmode=require
# Get a managed PostgreSQL instance from:
#   - Render PostgreSQL - recommended; auto-provisioned via render.yaml (matrix-spins-db)
#   - Supabase (https://supabase.com)
#   - Any external PostgreSQL (set DATABASE_URL manually)
DATABASE_URL=

# [optional] SQLite path used as local-dev fallback only
DB_PATH=./casino.db

# ── Auth & Secrets ───────────────────────────────────────────────────
# [REQUIRED] 32+ char random string. Generate: `openssl rand -hex 32`
JWT_SECRET=
# [REQUIRED] Admin dashboard password
# IMPORTANT: If value contains # or special chars, wrap in double quotes:
#   ADMIN_PASSWORD="MyP@ss#Word!"
ADMIN_PASSWORD=
# [recommended] Header `x-admin-api-key` value for admin-only routes
ADMIN_API_KEY=
# [recommended] Used to verify webhook signatures from internal services
WEBHOOK_SECRET=

# ── CORS ─────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call the API.
ALLOWED_ORIGIN=https://msaart.online

# ── Geo Compliance ───────────────────────────────────────────────────
# Geo-blocking has been removed — no country/IP gating on registration or
# payments. The casino is open to all jurisdictions. (No ALLOWED_COUNTRIES /
# BLOCKED_COUNTRIES / GEO_FAIL_MODE env vars are read anymore.)

# ── Stripe (card deposits) ───────────────────────────────────────────
# [REQUIRED for card deposits] live keys when NODE_ENV=production,
# test keys (sk_test_ / pk_test_) for staging.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Crypto deposits ──────────────────────────────────────────────────
# [optional] Receive on-chain deposits at these addresses
CRYPTO_WALLET_ADDRESS=
BTC_WALLET_ADDRESS=
ETH_RPC_URL=https://cloudflare-eth.com
ETH_CHAIN_ID=1
CRYPTO_MIN_CONFIRMATIONS=2
ETH_AUD_FALLBACK_RATE=5000

# ── Email / SMTP ─────────────────────────────────────────────────────
# [recommended] enables password reset, OTP, transactional email
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Matrix Spins" <noreply@msaart.online>
ADMIN_EMAIL=admin@msaart.online

# ── Withdrawal protection ────────────────────────────────────────────
WITHDRAWAL_OTP_THRESHOLD=500        # Withdrawals at/above $USD require email OTP
TERMS_VERSION=1                     # Bump when terms.html changes materially

# ── Rate limits (per minute, env-tunable) ────────────────────────────
RL_AUTH=5
RL_API=100
RL_SPIN=60
RL_ADMIN=30

# ── Slow query / perf logging ────────────────────────────────────────
SLOW_REQUEST_MS=1500                # log requests slower than this
SLOW_QUERY_MS=500                   # log DB queries slower than this
HEAP_WATCH_INTERVAL_MS=300000       # heap-usage sample every 5 min (0 disables)
HEAP_WATCH_GROWTH_MB=50             # warn when heap grows this much across samples

# ── Blockchain (audit trail — DB remains source of truth) ────────────
THIRDWEB_SECRET_KEY=
CONTRACT_ADDRESS=                   # leave empty for simulated mode

# ── Monitoring / Alerting ────────────────────────────────────────────
SENTRY_DSN=                         # [optional] error reporting
ALERT_WEBHOOK_URL=                  # [optional] Slack/Discord webhook for critical errors
MONITOR_TARGET_URL=https://msaart.online
MONITOR_INTERVAL_MS=60000           # scripts/monitor.js poll interval

# ── Seed defaults (used by `npm run seed`) ───────────────────────────
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@msaart.online
SEED_ADMIN_PASSWORD=                # falls back to ADMIN_PASSWORD if unset
