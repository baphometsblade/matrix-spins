  ],
  "product_offers": [
    {
      "original_site": "Amazon",
      "product_title_keywords": ["Example Laptop Model"],
      "category": "Gaming Laptops",
      "offer": {
        "text": "Get $50 cash back on this laptop!",
        "url": "https://my-partner-network.com/special-offer/laptop-deal",
        "cash_back_amount": 50.00
      }
    }
  ],
  "category_offers": [
    {
      "category": "Gaming Laptops",
      "offer": {
        "text": "Based on your interest in {category}, check out this deal!",
        "url": "https://my-partner-network.com/category-deal/gaming-laptops",
        "cash_back_amount": 25.00
      }
    }
  ],
  "scraping_rules": [
    {
      "site": "Amazon",
      "price_selector": ".a-price .a-offscreen"
    }
  ],
  "coupon_codes": [
    {
      "retailer_hostname": "mock-checkout.com",
      "coupons": [
        { "code": "SAVE10", "discount_value": 10, "type": "percent" },
        { "code": "20OFF", "discount_value": 20, "type": "fixed" },
