        "ethers": "^5.7.2",
        "express": "^4.18.2",
        "express-rate-limit": "^7.1.5",
        "helmet": "^7.1.0",
        "jsonwebtoken": "^9.0.2",
        "node-cron": "^4.2.1",
        "nodemailer": "^8.0.1",
        "pg": "^8.18.0",
