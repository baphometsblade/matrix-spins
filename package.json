{
  "name": "matrix-spins-casino",
  "version": "2.0.0",
  "description": "Matrix Spins Casino — Premium Online Slots Platform",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node server/index.js",
    "build": "node scripts/bundle-js.js || echo no-bundle-step",
    "migrate": "node scripts/migrate.js",
    "seed": "node scripts/seed.js",
    "monitor": "node scripts/monitor.js",
    "monitor:once": "node scripts/monitor.js --once",
    "lint": "eslint --ext .js server/ scripts/ api/ shared/ blockchain/ --cache --no-error-on-unmatched-pattern",
    "lint:fix": "eslint --ext .js server/ scripts/ api/ shared/ blockchain/ --fix --no-error-on-unmatched-pattern",
    "lint:strict": "eslint --ext .js server/middleware/metrics.js server/utils/heap-watch.js server/utils/slow-query.js scripts/migrate.js scripts/seed.js scripts/monitor.js --max-warnings=0",
    "qa:regression": "node scripts/qa_regression.js",
    "qa:smoke": "node scripts/smoke-money-flow.js",
    "qa:rtp": "node scripts/verify-rtp.js",
    "test": "jest --runInBand --forceExit",
    "test:unit": "jest --runInBand --forceExit tests/unit",
    "test:integration": "jest --runInBand --forceExit tests/integration",
    "test:coverage": "jest --runInBand --forceExit --coverage",
    "test:watch": "jest --watch",
    "prepare": "husky || echo husky-skipped"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testTimeout": 30000,
    "verbose": true,
    "clearMocks": true,
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text-summary",
      "lcov",
      "html"
    ],
    "collectCoverageFrom": [
      "server/**/*.js",
      "shared/**/*.js",
      "blockchain/**/*.js",
      "!server/index.js",
      "!**/node_modules/**"
    ]
  },
  "keywords": [
    "casino",
    "slots",
    "gaming"
  ],
  "author": "Matrix Spins",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.15",
    "pg": "^8.13.1",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.3",
    "speakeasy": "^2.0.0",
    "sql.js": "^1.12.0",
    "stripe": "^14.21.0",
    "uuid": "^10.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "optionalDependencies": {
    "canvas": "^3.2.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "clean-css": "^5.3.3",
    "eslint": "^8.57.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "sharp": "^0.34.5",
    "supertest": "^7.0.0",
    "terser": "^5.46.2"
  }
}
